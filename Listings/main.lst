 894   1        {
 895   2          if((Sys.Tick_ms % 63) == 0)
 896   2            Sys.Strobe_Phase ^= 1;
 897   2        }
 898   1        else
 899   1          Sys.Strobe_Phase = 1;
 900   1      
 901   1        Task_Marks_Handler_Callback();
 902   1      }
