1170          // 函数: ADCRead
C51 COMPILER V9.60.0.0   MAIN                                                              07/18/2026 18:21:10 PAGE 20  

1171          // 描述: 查询法读取一次ADC转换结果.
1172          // 参数: ChX - ADC通道号(0~15).
1173          // 返回: ADC结果,失败返回4096.
1174          //========================================================================
1175          unsigned int ADCRead(unsigned char ChX)
1176          {
1177   1        unsigned int res;
1178   1        unsigned char i;
1179   1      
1180   1        if(ChX > 15) return 4096;
1181   1        ADC_RES = 0;
1182   1        ADC_RESL = 0;
1183   1        ADC_CONTR = (ADC_CONTR & 0xf0) | 0x40 | ChX;
1184   1        _nop_();
1185   1        _nop_();
1186   1      
1187   1        for(i = 0; i < 250; i++)
1188   1        {
1189   2          if(ADC_CONTR & 0x20)
1190   2          {
1191   3            ADC_CONTR &= ~0x20;
1192   3            res = ((unsigned int)ADC_RES << 8) | ADC_RESL;
1193   3            return res;
1194   3          }
1195   2        }
1196   1        return 4096;
1197   1      }
