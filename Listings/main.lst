 685          //========================================================================
 686          // 函数: Usart_HandleCmd
 687          // 描述: 串口命令解析(帧格式: <>命令).
 688          // 参数: None.
 689          // 返回: None.
 690          //
 691          // 查询命令(C51须用%bu打印unsigned char, 否则参数栈错位):
 692          //   <A1> 版本号    <A2> 温度    <A3> 电池电压
 693          //   <A4> 当前模式  <A5> 完整状态
 694          // 控制命令:
 695          //   <M00>~<M13> 设置模式  <B0> 全关
 696          //   <C1=0/1> 激光  <C2=0/1> 白光强  <C3=0/1> 白光弱
 697          //   <C4=0/1> 绿光  <C5=0/1> 红光  <D1=0/1> 爆闪
 698          //   <>REBOOT 重启
 699          //========================================================================
 700          static void Usart_HandleCmd(void)
 701          {
 702   1        char *p = COM1.RX_Buffer;
 703   1      
 704   1        if(p[0] != '<' || p[1] != '>') return;
 705   1      
 706   1        /* A类: 查询命令 */
 707   1        if(p[2] == 'A')
 708   1        {
 709   2          if(p[3] == '1')
 710   2            printf("Ver=%bu.%bu\r\n", Sys.Ver_Major, Sys.Ver_Minor);
 711   2          else if(p[3] == '2')
 712   2            printf("Temp=%.1f\r\n", Sys.Board_Temp);
 713   2          else if(p[3] == '3')
 714   2            printf("Vref=%.2f\r\n", Sys.Vref_Voltage);
 715   2          else if(p[3] == '4')
 716   2            printf("Mode=%bu\r\n", Sys.Light_Mode);
 717   2          else if(p[3] == '5')
 718   2            Status_Report();
 719   2          return;
 720   2        }
 721   1      
 722   1        /* M类: 模式设置 <M00>~<M13> */
 723   1        if(p[2] == 'M' && p[3] >= '0' && p[3] <= '9')
 724   1        {
 725   2          unsigned char mode = (p[3] - '0');
 726   2          if(p[4] >= '0' && p[4] <= '9')
 727   2            mode = mode * 10 + (p[4] - '0');
 728   2          if(mode <= MODE_GREEN_HOLD)
 729   2          {
 730   3            if(mode == MODE_OFF)
 731   3            {
 732   4              Output_AllOff();
 733   4              printf("OK\r\n");
 734   4            }
 735   3            else if(Mode_StartBlocked())
 736   3              printf("ERR\r\n");
C51 COMPILER V9.60.0.0   MAIN                                                              07/18/2026 18:21:10 PAGE 13  

 737   3            else
 738   3            {
 739   4              Mode_Set(mode);
 740   4              printf("OK\r\n");
 741   4            }
 742   3          }
 743   2          else
 744   2            printf("ERR\r\n");
 745   2          return;
 746   2        }
 747   1      
 748   1        /* B类: 全关 */
 749   1        if(p[2] == 'B' && p[3] == '0')
 750   1        {
 751   2          Output_AllOff();
 752   2          printf("OK\r\n");
 753   2          return;
 754   2        }
 755   1      
 756   1        /* C类: 独立通道控制 <Cx=0/1> */
 757   1        if(p[2] == 'C' && p[4] == '=' && (p[5] == '0' || p[5] == '1'))
 758   1        {
 759   2          unsigned char on = (p[5] == '1');
 760   2          if(on && Mode_StartBlocked())
 761   2          {
 762   3            printf("ERR\r\n");
 763   3            return;
 764   3          }
 765   2          if(p[3] == '1') { Sys.Out_Laser = on; Sys.Light_Mode = on ? MODE_LASER_HOLD : MODE_OFF; }
 766   2          else if(p[3] == '2') { Sys.Out_White = on ? 1 : 0; if(on) Sys.Light_Mode = MODE_WHITE_HOLD; }
 767   2          else if(p[3] == '3') { Sys.Out_White = on ? 2 : 0; if(on) Sys.Light_Mode = MODE_WHITE_DIM_HOLD; }
 768   2          else if(p[3] == '4') { Sys.Out_Green = on; if(on) Sys.Light_Mode = MODE_GREEN_HOLD; }
 769   2          else if(p[3] == '5') { Sys.Out_Red = on; if(on) Sys.Light_Mode = MODE_RED_HOLD; }
 770   2          else { printf("ERR\r\n"); return; }
 771   2          if(!on && !Sys.Out_Laser && !Sys.Out_White && !Sys.Out_Green && !Sys.Out_Red)
 772   2            Sys.Light_Mode = MODE_OFF;
 773   2          printf("OK\r\n");
 774   2          return;
 775   2        }
 776   1      
 777   1        /* D类: 爆闪控制 <D1=0/1> */
 778   1        if(p[2] == 'D' && p[3] == '1' && p[4] == '=' && (p[5] == '0' || p[5] == '1'))
 779   1        {
 780   2          unsigned char on = (p[5] == '1');
 781   2          if(on && Sys.Out_White == 0 && Mode_StartBlocked())
 782   2          {
 783   3            printf("ERR\r\n");
 784   3            return;
 785   3          }
 786   2          Sys.Strobe_On = on;
 787   2          if(Sys.Strobe_On && Sys.Out_White == 0)
 788   2            Sys.Out_White = 1;
 789   2          printf("OK\r\n");
 790   2          return;
 791   2        }
 792   1      
 793   1        /* 重启 */
 794   1        if(p[2] == 'R' && p[3] == 'E' && p[4] == 'B' && p[5] == 'O' && p[6] == 'O' && p[7] == 'T')
 795   1        {
 796   2          IAP_CONTR |= 0x60;
 797   2          return;
 798   2        }
C51 COMPILER V9.60.0.0   MAIN                                                              07/18/2026 18:21:10 PAGE 14  

 799   1      
 800   1        printf("ERR\r\n");
 801   1      }
