 821          //========================================================================
 822          // 函数: App_Analysis_Task
 823          // 描述: ADC采集与NTC温度计算,周期500ms.
 824          // 参数: None.
 825          // 返回: None.
 826          //========================================================================
 827          void App_Analysis_Task(void)
 828          {
 829   1        unsigned int AD_Board_Temp, AD_Vref_Voltage;
 830   1        float T2 = 298.15;                  //参考温度25℃(K)
 831   1        float Ka = 273.15;
 832   1        float V_adc, R_ntc;
 833   1        int *BGV;
 834   1      
 835   1        BGV = (int idata *)0xef;
 836   1      
 837   1        AD_Vref_Voltage = ADCRead(15);
 838   1        AD_Board_Temp = ADCRead(0);
 839   1      
 840   1        Sys.Vref_Voltage = 1.024 * *BGV / AD_Vref_Voltage;
 841   1      
 842   1        /*
 843   1         * 分压电路: Vcc--[NTC]--P10(ADC)--[10K]--GND  (NTC在高端)
 844   1         * V_adc = Vcc * Rpull / (Rntc + Rpull)
 845   1         * Rntc  = Rpull * (Vcc - V_adc) / V_adc
 846   1         */
 847   1        V_adc = (float)AD_Board_Temp / ADC_FULL_SCALE * NTC_SUPPLY_V;
 848   1        if(V_adc < 0.01f)
 849   1          V_adc = 0.01f;
 850   1        R_ntc = NTC_R_PULL * (NTC_SUPPLY_V - V_adc) / V_adc;
 851   1      
 852   1        Sys.Board_Temp = 1.0f / (1.0f / T2 + log(R_ntc / NTC_R25) / NTC_B_VALUE) - Ka + 0.5f;
 853   1      
 854   1        /* 温度限幅 */
 855   1        if(Sys.Board_Temp < -40)
 856   1          Sys.Board_Temp = -40;
 857   1        else if(Sys.Board_Temp > 120)
 858   1          Sys.Board_Temp = 120;
 859   1      
 860   1        Battery_Check();
C51 COMPILER V9.60.0.0   MAIN                                                              07/18/2026 18:21:10 PAGE 15  

 861   1      }
