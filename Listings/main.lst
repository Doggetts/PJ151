 514          // 描述: 单颗按键扫描与手势识别(消抖/单击/双击/长按).
 515          // 参数: k - 按键状态; raw - 原始电平; gear - 档位; key_id - 1红2绿3弱.
 516          // 返回: None.
 517          //========================================================================
 518          static void Key_Process(KEY_SCAN_TYPE *k, unsigned char raw, unsigned char gear, unsigned char key_id)
 519          {
 520   1        /* 电平变化消抖 */
 521   1        if(raw != k->stable)
 522   1        {
 523   2          k->debounce_ms += 20;
 524   2          if(k->debounce_ms >= KEY_DEBOUNCE_MS)
 525   2          {
 526   3            k->stable = raw;
 527   3            k->debounce_ms = 0;
 528   3      
 529   3            if(k->stable == 0)          //按下沿
 530   3            {
 531   4              k->pressed = 1;
 532   4              k->hold_ms = 0;
 533   4              if(k->click_wait_ms > 0 && k->click_cnt == 1)   //双击第二下
 534   4              {
 535   5                k->click_cnt = 2;
 536   5                k->click_wait_ms = 0;
 537   5                k->dbl_wait = 1;
 538   5                k->second_hold_ms = 0;
 539   5              }
 540   4            }
 541   3            else                        //松开沿
 542   3            {
 543   4              if(k->pressed)
 544   4              {
 545   5                if(!k->long1_done && !k->long10_done && !k->dbl_wait)
 546   5                  k->click_cnt++;
 547   5                Key_OnRelease(k, gear, key_id);
 548   5              }
 549   4              k->pressed = 0;
 550   4            }
