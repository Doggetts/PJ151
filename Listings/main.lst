 551   3          }
 552   2        }
 553   1        else
 554   1          k->debounce_ms = 0;
 555   1      
 556   1        /* 按下保持中 */
 557   1        if(k->pressed && k->stable == 0)
 558   1        {
 559   2          if(k->hold_ms < 60000)
 560   2            k->hold_ms += 20;
 561   2      
 562   2          /* 双击第二下按住判定 */
 563   2          if(k->dbl_wait)
 564   2          {
 565   3            if(k->second_hold_ms < 60000)
 566   3              k->second_hold_ms += 20;
 567   3            if(k->second_hold_ms > KEY_DBLHOLD_MS)
 568   3            {
 569   4              k->dbl_hold_arm = 1;
 570   4              Key_OnDoubleHold(gear, key_id);
 571   4            }
 572   3          }
 573   2      
 574   2          /* 右档长按1s */
 575   2          if(gear == GEAR_RIGHT && (key_id == 1 || key_id == 2))
 576   2          {
 577   3            if(k->hold_ms >= KEY_LONG1_MS)
 578   3              Key_OnLong1(k, gear, key_id);
 579   3          }
 580   2      
 581   2          /* 左档红/绿键处理 */
 582   2          if(gear == GEAR_LEFT && (key_id == 1 || key_id == 2))
 583   2          {
 584   3            if(k->hold_ms >= KEY_LONG10_MS)         //长按10s锁定常亮
 585   3              Key_OnLong10(k, gear, key_id);
 586   3            else if(!k->long10_done)
 587   3            {
 588   4              if(key_id == 1 && Sys.Light_Mode != MODE_RED_HOLD)
 589   4              {
 590   5                if(Mode_StartBlocked()) return;
 591   5                Sys.Light_Mode = MODE_RED_MOMENT;
 592   5                Sys.Out_Red = 1;
 593   5                Sys.Moment_Active = 1;
 594   5              }
 595   4              else if(key_id == 2 && Sys.Light_Mode != MODE_GREEN_HOLD)
 596   4              {
 597   5                if(Mode_StartBlocked()) return;
 598   5                Sys.Light_Mode = MODE_GREEN_MOMENT;
 599   5                Sys.Out_Green = 1;
 600   5                Sys.Moment_Active = 1;
 601   5              }
 602   4            }
 603   3          }
 604   2        }
 605   1      
 606   1        /* 单击等待超时,判定为单次点击 */
 607   1        if(k->click_wait_ms > 0)
 608   1        {
 609   2          if(k->click_wait_ms > 20)
 610   2            k->click_wait_ms -= 20;
 611   2          else
 612   2          {
C51 COMPILER V9.60.0.0   MAIN                                                              07/18/2026 18:21:10 PAGE 11  

 613   3            if(k->click_cnt == 1)
