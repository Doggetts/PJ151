 629          // 函数: App_Key_Task
 630          // 描述: 按键处理任务,周期20ms.
 631          // 参数: None.
 632          // 返回: None.
 633          //========================================================================
 634          void App_Key_Task(void)
 635          {
 636   1        unsigned char gear;
 637   1        static unsigned char gear_last = 0xFF;
 638   1      
 639   1        gear = Gear_Get();
 640   1      
 641   1        /* 任意档位改变则关闭输出并复位按键状态 */
 642   1        if(gear != gear_last)
 643   1        {
 644   2          if(gear_last != 0xFF)
 645   2          {
 646   3            Output_AllOff();
 647   3            Output_Apply();
 648   3            Key_Reset(&KeyRed);
 649   3            Key_Reset(&KeyGreen);
 650   3            Key_Reset(&KeyWeak);
 651   3            Sys.MidHold_ms = 0;
 652   3          }
 653   2          gear_last = gear;
 654   2        }
 655   1        Sys.Gear = gear;
 656   1      
 657   1        if(gear == GEAR_RIGHT || gear == GEAR_LEFT)
 658   1        {
 659   2          Key_Process(&KeyRed,   Key_Read(KEY_RED),   gear, 1);
 660   2          Key_Process(&KeyGreen, Key_Read(KEY_GREEN), gear, 2);
 661   2          Key_Process(&KeyWeak,  Key_Read(KEY_WEAK),  gear, 3);
 662   2        }
 663   1        else
 664   1        {
 665   2          Key_Reset(&KeyRed);
 666   2          Key_Reset(&KeyGreen);
 667   2          Key_Reset(&KeyWeak);
 668   2        }
 669   1      
 670   1        /* 中档保持5s后进入休眠, P32上升沿唤醒 */
 671   1        if(Sys.Gear == GEAR_MID)
 672   1        {
 673   2          if(Sys.MidHold_ms < 65000)
 674   2            Sys.MidHold_ms += 20;
C51 COMPILER V9.60.0.0   MAIN                                                              07/18/2026 18:21:10 PAGE 12  

 675   2          if(Sys.MidHold_ms >= MID_SHUTDOWN_MS)
 676   2          {
 677   3            Sys.MidHold_ms = 0;
 678   3            ShutDown();
 679   3          }
 680   2        }
 681   1        else
 682   1          Sys.MidHold_ms = 0;
 683   1      }
