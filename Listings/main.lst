 615   4              /* 左档红/绿常亮模式下短按关闭 */
 616   4              if(gear == GEAR_LEFT && key_id == 1 && Sys.Light_Mode == MODE_RED_HOLD)
 617   4                Output_AllOff();
 618   4              else if(gear == GEAR_LEFT && key_id == 2 && Sys.Light_Mode == MODE_GREEN_HOLD)
 619   4                Output_AllOff();
 620   4              else
 621   4                Key_OnSingleClick(gear, key_id);
 622   4            }
 623   3            Key_Reset(k);
 624   3          }
 625   2        }
 626   1      }
